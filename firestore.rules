rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Admins only: stha123surya@gmail.com, neki123nki@gmail.com
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email_verified == true && 
             (request.auth.token.email == 'stha123surya@gmail.com' || request.auth.token.email == 'neki123nki@gmail.com');
    }

    function isValidProject(data) {
      return data.keys().hasAll(['title', 'category', 'description', 'image']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 150 &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 50 &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 5000 &&
             data.image is string && data.image.size() >= 0 && data.image.size() <= 2000;
    }

    function isValidArticle(data) {
      return data.keys().hasAll(['title', 'content', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 50000 &&
             data.createdAt == request.time &&
             (data.get('coverImage', '') is string);
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    match /projects/{projectId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProject(incoming());
      allow update: if isAdmin() && isValidProject(incoming());
      allow delete: if isAdmin();
    }

    match /articles/{articleId} {
      allow read: if true;
      allow create: if isAdmin() && isValidArticle(incoming());
      allow update: if isAdmin() && 
                    incoming().diff(existing()).affectedKeys().hasAny(['title', 'content', 'coverImage']) &&
                    incoming().title is string && incoming().title.size() > 0 && incoming().title.size() <= 200 &&
                    incoming().content is string && incoming().content.size() > 0 && incoming().content.size() <= 50000 &&
                    incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();
    }

    match /hobbies/{hobbyId} {
      allow read: if true;
      allow create: if isAdmin() && isValidArticle(incoming());
      allow update: if isAdmin() && 
                    incoming().diff(existing()).affectedKeys().hasAny(['title', 'content', 'coverImage']) &&
                    incoming().title is string && incoming().title.size() > 0 && incoming().title.size() <= 200 &&
                    incoming().content is string && incoming().content.size() > 0 && incoming().content.size() <= 50000 &&
                    incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();
    }
  }
}
